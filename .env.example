# =============================================================================
# LLM Provider Chain (multi-model fallback)
# =============================================================================
# Set at least one of these. The pipeline will use them in this order:
#   1. OPENCODE_GO_API_KEY -> DeepSeek V4 Flash via OpenCode Go (primary, generous)
#   2. GEMINI_API_KEY       -> Gemini 2.5 Flash (best quality, 5 RPM / 20 RPD)
#   3. GEMINI_MODEL_LITE    -> Gemini 2.5 Flash-Lite (1,500 RPD, same key)
#   4. OPENROUTER_*         -> free model via OpenRouter
#   5. GROQ_*               -> free model via Groq
#   6. XAI_*                -> xAI Grok (free tier credit)

# OpenCode Go (https://opencode.ai/auth) — subscription primary
OPENCODE_GO_API_KEY=""

# Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_MODEL_LITE="gemini-2.5-flash-lite"
GEMINI_RATE_LIMIT_DELAY="13"

# OpenRouter (https://openrouter.ai/keys) — free models
# Use any model with ":free" suffix. Examples:
#   meta-llama/llama-3.3-70b-instruct:free
#   google/gemini-2.0-flash-exp:free
#   qwen/qwen-2.5-72b-instruct:free
OPENROUTER_CRAWLER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"

# Groq (https://console.groq.com/keys) — very fast, 14,400 RPD free
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# xAI Grok (https://console.x.ai)
# Works from the pipeline server regardless of where the operator is located
# (xAI blocks access from some regions only on their website, not the API).
XAI_API_KEY=""
XAI_MODEL="grok-3-mini"

# =============================================================================
# Database (Supabase PostgreSQL)
# =============================================================================
DB_PASS=""

# =============================================================================
# SSH Configuration (for database sync)
# =============================================================================
SSH_HOST="server123.web-hosting.com"
SSH_USER="fomoowsq"
SSH_PORT="21098"

# =============================================================================
# Production Database (for sync script)
# =============================================================================
PROD_DB_NAME="postgres"
PROD_DB_USER=""
PROD_DB_PASS="your_db_password"
