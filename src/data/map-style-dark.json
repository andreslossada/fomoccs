  "glyphs": "fonts/glyphs/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "transparent"
      }
    },
    {
      "id": "earth",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "earth",
      "paint": {
        "fill-color": "#1d1d1d"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "paint": {
        "fill-color": "transparent"
      }
    },
    {
      "id": "landuse-park",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["any",
        ["==", "kind", "park"],
        ["==", "kind", "forest"]
      ],
      "paint": {
        "fill-color": "#1d331d"
      }
    },
    {
      "id": "landuse-cemetery",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["any",
        ["==", "kind", "cemetery"],
        ["==", "kind", "golf_course"]
      ],
      "paint": {
        "fill-color": "#1a261a"
      }
    },
    {
      "id": "landuse-beach",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["==", "kind", "beach"],
      "paint": {
        "fill-color": "#3d3526"
      }
    },
    {
      "id": "roads-highway",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["==", "kind", "highway"],
      "paint": {
        "line-color": "#363636",
        "line-width": [
          "interpolate", ["exponential", 1.5], ["zoom"],
          5, 1,
          10, 2.5,
          14, 5,
          18, 14
        ]
      }
    },
    {
      "id": "roads-major",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["==", "kind", "major_road"],
      "paint": {
        "line-color": "#2f2f2f",
        "line-width": [
          "interpolate", ["exponential", 1.5], ["zoom"],
          7, 0.3,
          10, 1,
          14, 3,
          18, 10
        ]
      }
    },
    {
      "id": "roads-minor",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["==", "kind", "minor_road"],
      "minzoom": 12,
      "paint": {
        "line-color": "#2c2c2c",
        "line-width": [
          "interpolate", ["exponential", 1.5], ["zoom"],
          12, 0.5,
          14, 1,
          18, 5
        ]
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "buildings",
      "minzoom": 13,
      "paint": {
        "fill-color": "#2a2a2a",
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          13, 0,
          14, 0.7
        ]
      }
    },
    {
      "id": "roads-labels-major",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "highway", "major_road"],
      "minzoom": 11,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name"],
        "text-font": ["Inter Regular"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          11, 9,
          14, 11,
          18, 14
        ],
        "text-max-angle": 30
      },
      "paint": {
        "text-color": "#777",
        "text-halo-color": "#1a1a1a",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-labels-neighborhood",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["==", "kind", "neighbourhood"],
      "minzoom": 12,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Inter SemiBold"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          12, 10,
          14, 12,
          16, 14
        ],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.1
      },
      "paint": {
        "text-color": "#888",
        "text-halo-color": "#1a1a1a",
        "text-halo-width": 2
      }
    },
    {
      "id": "barrio-labels",
      "type": "symbol",
      "source": "barrios",
      "minzoom": 11,
      "maxzoom": 16,
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Inter SemiBold"],
        "text-size": [
          "interpolate", ["linear"], ["zoom"],
          11, 10,
          13, 12,
          15, 14
        ],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.1,
        "text-allow-overlap": false,
        "text-padding": 10
      },
      "paint": {
        "text-color": "#888",
        "text-halo-color": "#1a1a1a",
        "text-halo-width": 2
      }
    }
